APP_NAME=PaperLens API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 선택: CrossRef polite pool용 연락 이메일 (설정 시 User-Agent에 포함)
CROSSREF_MAILTO=
# 리뷰 노트 SQLite 파일 경로 (DATABASE_URL이 비어 있을 때 사용)
DATABASE_PATH=paperlens.db
# PostgreSQL 사용 시 설정. 로컬 compose 기본값:
# postgresql://paperlens:paperlens_dev@127.0.0.1:5432/paperlens
DATABASE_URL=
