APP_NAME=PaperLens API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 선택: CrossRef polite pool용 연락 이메일 (설정 시 User-Agent에 포함)
CROSSREF_MAILTO=
# 리뷰 노트 SQLite 파일 경로 (DATABASE_URL이 비어 있을 때 사용)
DATABASE_PATH=paperlens.db
# PostgreSQL 사용 시 설정. 로컬 compose 기본값:
# postgresql://paperlens:paperlens_dev@127.0.0.1:5432/paperlens
DATABASE_URL=

# Phase 2 AI 보조 레이어(OpenRouter). 비워두면 AI 버튼은 비활성/미설정 상태로 동작합니다.
AI_API_KEY=
AI_MODEL=openai/gpt-5.2
AI_SITE_URL=https://nebu-25.github.io/Paperlens_26.06/
AI_APP_NAME=PaperLens

# Supabase Auth (SUPABASE_JWT_SECRET이 있으면 보호 API가 Bearer token을 요구합니다)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SAMPLE_PDF_URL=

# OCR fallback (optional): NAVER CLOVA OCR API
OCR_ENABLED=false
OCR_MAX_PAGES=20
OCR_DPI=200
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET_KEY=
CLOVA_OCR_TIMEOUT_SEC=30
