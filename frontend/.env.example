# API 베이스 URL. 비워두면 상대경로 /api 를 사용합니다.
#  - 개발: Vite 프록시(vite.config.ts)가 /api 를 백엔드로 전달
#  - 배포: 프론트와 동일 오리진(또는 리버스 프록시)에서 /api 제공
# 다른 오리진의 백엔드를 직접 가리키려면 예: http://127.0.0.1:8000
VITE_API_BASE_URL=

# Supabase Auth (로그인/개인 라이브러리)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 선택: 랜딩 로그인 폼에 데모 계정을 미리 채웁니다. 공개 배포 빌드에 포함되므로
# 실제 사용자 권한이 있는 계정이 아니라 데모 전용 계정만 넣으세요.
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD=
